<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ page_title }}{% endblock %}</title>
  {% block stylesheets %}
  <link href="{{ bootstrap_css }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ bootstrap_icons }}">
  <link rel="stylesheet" href="{{ asset_prefix }}css/amsom.css">
  {% endblock %}
</head>
<body>
{% block body %}{% endblock %}
{% block javascripts %}
  <script src="{{ bootstrap_js }}"></script>
  <script src="{{ asset_prefix }}js/amsom.js"></script>
{% endblock %}
</body>
</html>
